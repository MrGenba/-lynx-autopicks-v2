# Postgres propio de este sistema (NO Supabase) -- provisto por EasyPanel
DATABASE_URL=postgresql://autopicks:CHANGEME@autopicks-db:5432/autopicks

# Supabase del proyecto Lynx Hunter -- SOLO LECTURA desde este sistema, nunca se escribe
SUPABASE_URL=https://htpllgcsjwasptaxheph.supabase.co
SUPABASE_KEY=

# Bot de Telegram NUEVO (creado via BotFather) -- SOLO hace polling (getUpdates) para recibir
# cuotas y comandos. No puede ser el mismo token que @Lynx_HunterBot porque ese usa webhook en
# n8n (webhook + polling en el mismo bot chocan).
TG_BOT_TOKEN=
# @Lynx_HunterBot (produccion) -- SOLO se usa para publicar picks al canal de produccion.
# Enviar mensajes (sendMessage) no choca con el webhook de ese bot, solo RECIBIR chocaria.
# NUNCA pongas aqui el token real -- este archivo es una plantilla publica, el valor real
# solo vive en las variables de entorno del servicio en EasyPanel.
TG_PICKS_BOT_TOKEN=
# Chat privado del admin (tu chat_id) para avisos y comandos /status /pending /picks
TG_ADMIN_CHAT_ID=
# Canal de picks -- por decision explicita del usuario, es el canal de PRODUCCION existente
# (no uno separado). Los picks de v2 llevan la etiqueta "[Auto-Picks v2 - experimental]" para
# no confundirse con los picks reales del pipeline n8n.
TG_PICKS_CHANNEL_ID=

# Ruta al binario de node (para el puente vendor/run_quant.js)
NODE_BIN=node
VENDOR_DIR=/app/vendor

LOG_LEVEL=INFO
LOG_DIR=/app/logs

# Cada cuantos segundos corre el detector (Gate A/B)
DETECTOR_INTERVAL_SECONDS=180

# Cada cuantos segundos corre el scraper automatico de cuotas (cuotasahora.com). Cada ciclo
# scrapea la liga ENTERA, no solo un partido -- intervalo largo a proposito, para no arriesgarse
# a otro bloqueo de IP como el que ya sufrio el VPS de Francia.
ODDS_AUTOFETCH_INTERVAL_SECONDS=900
# false (por defecto) = el job automatico NO se registra, solo /fetchodds manual por Telegram.
# Pausado 2026-07-09 tras un gasto inesperado de proxy durante la depuracion -- reactivar
# cuando se confirme cuanto gasta realmente el ciclo ya optimizado (filtro URL + sin imagenes).
ODDS_AUTOFETCH_ENABLED=false

# Proxy opcional para el scraper de cuotas (necesario: el VPS de Francia esta bloqueado por
# cuotasahora.com). Vacio = sin proxy, el scraper fallara igual que produccion.
# NUNCA pongas aqui las credenciales reales -- solo en las variables de entorno del servicio
# en EasyPanel, igual que con TG_PICKS_BOT_TOKEN.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Token compartido para el endpoint HTTP GET /scrape-odds?league=MLB&token=... -- lo usa
# produccion (n8n, proyecto EasyPanel distinto) para reusar el scraper con Tor de este
# contenedor en vez de duplicar Tor+Chrome alli. Vacio = endpoint desactivado (siempre 401).
# NUNCA pongas aqui el valor real -- solo en las variables de entorno del servicio en EasyPanel.
SCRAPE_ENDPOINT_TOKEN=
